ragraph\\\",\\\"model\\\":{\\\"text\\\":\\\"\u00a0\\\",\\\"blocks\\\":[{\\\"type\\\":\\\"fragment\\\",\\\"model\\\":{\\\"text\\\":\\\"\u00a0\\\",\\\"attributes\\\":[]}}]}}]\"}},\"metadata\":{\"contributor\":\"Daniel Bush\",\"contributors\":\"Daniel Bush\",\"description\":\"As the US vice-president leads peace talks with Iran, he must balance warring factions, a demanding boss and his own political future.\",\"firstPublished\":1775868863297,\"lastPublished\":1775868863297,\"lastUpdated\":1775933710000,\"indexImage\":{\"blocks\":[{\"type\":\"caption\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"A treated image of JD Vance showing a building in Lebanon being struck by a missile and a silhouette of Donald Trump on the right\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"A treated image of JD Vance showing a building in Lebanon being struck by a missile and a silhouette of Donald Trump on the right\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":1920,\"height\":1080,\"locator\":\"5c19/live/ef4d3250-3522-11f1-879d-1b2f5c3919b8.jpg\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"Reuters\",\"suitableForSyndication\":true}}],\"originalSrc\":\"https://c.files.bbci.co.uk/5c19/live/ef4d3250-3522-11f1-879d-1b2f5c3919b8.jpg\",\"isEditorialImage\":true,\"height\":1080,\"width\":1920,\"alt\":\"A treated image of JD Vance showing a building in Lebanon being struck by a missile and a silhouette of Donald Trump on the right\"},\"seoHeadline\":\"JD Vance takes on a perilous mission - could it backfire?\",\"promoHeadline\":\"JD Vance takes on a perilous mission - could it backfire?\",\"section\":{\"name\":\"BBC InDepth\",\"uri\":\"/news/bbcindepth\"},\"options\":{\"includeComments\":false,\"allowAdvertising\":true},\"wordCount\":1873,\"pillar\":[{\"title\":\"News\",\"url\":\"/news\"}]},\"pageKey\":\"@\\\"news\\\",\\\"articles\\\",\\\"c1d9z1q2997o\\\",\",\"page\":{\"@\\\"news\\\",\\\"articles\\\",\\\"c1d9z1q2997o\\\",\":{\"id\":\"urn:bbc:optimo:asset:c1d9z1q2997o\",\"contents\":[{\"type\":\"headline\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"JD Vance takes on a perilous mission - could it backfire?\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"JD Vance takes on a perilous mission - could it backfire?\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"timestamp\",\"model\":{\"timestamp\":1775868863297}},{\"type\":\"byline\",\"model\":{\"blocks\":[{\"type\":\"contributor\",\"model\":{\"blocks\":[{\"type\":\"name\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Daniel Bush\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Daniel Bush\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"role\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Washington correspondent\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Washington correspondent\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"images\",\"model\":{\"blocks\":[{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"rawImage\",\"model\":{\"width\":800,\"height\":800,\"locator\":\"bc09/live/6e9c08b0-34c4-11f1-8606-05fe34b06e1b.png\",\"originCode\":\"cpsprodpb\"}},{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Daniel Bush\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Daniel Bush\",\"attributes\":[]}}]}}]}}]}}]}}]}}]}},{\"type\":\"timestamp\",\"model\":{\"timestamp\":1775868863297}}]}},{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"A treated image of JD Vance showing fighter jets in the sky, an Iranian flag, and a silhouette of Donald Trump on the right\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"A treated image of JD Vance showing fighter jets in the sky, an Iranian flag, and a silhouette of Donald Trump on the right\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":2500,\"height\":2500,\"locator\":\"15f2/live/fbcfab80-3521-11f1-879d-1b2f5c3919b8.jpg\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"BBC\",\"suitableForSyndication\":true}}],\"emphasiseImage\":true}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"In the middle of an Easter lunch at the White House, President Donald Trump went off script to address speculation about JD Vance's role in securing a deal to end the war in Iran.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"In the middle of an Easter lunch at the White House, President Donald Trump went off script to address speculation about JD Vance's role in securing a deal to end the war in Iran.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\\\"If it doesn't happen, I'm blaming JD Vance,\\\" Trump joked, drawing laughter at last week's East Room event attended by senior administration officials including the vice-president, Secretary of State Marco Rubio, and Defence Secretary Pete Hegseth. And \\\"if it does happen,\\\" Trump added, \\\"I'm taking full credit.\\\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\\\"If it doesn't happen, I'm blaming JD Vance,\\\" Trump joked, drawing laughter at last week's East Room event attended by senior administration officials including the vice-president, Secretary of State Marco Rubio, and Defence Secretary Pete Hegseth. And \\\"if it does happen,\\\" Trump added, \\\"I'm taking full credit.\\\"\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"The remarks perfectly captured Vance's predicament as he leads a US delegation holding talks with Iran in Pakistan. It is the most challenging assignment of Vance's vice-presidency so far - one with a limited upside and plenty to lose if negotiations fail.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"The remarks perfectly captured Vance's predicament as he leads a US delegation holding talks with Iran in Pakistan. It is the most challenging assignment of Vance's vice-presidency so far - one with a limited upside and plenty to lose if negotiations fail.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Vance's diplomatic mission to Islamabad is a political minefield. To make progress in reaching a permanent agreement to end the war, he will have to satisfy several stakeholders with competing interests, and who all distrust each other after a six-week military campaign that has engulfed the Middle East and roiled the global economy.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Vance's diplomatic mission to Islamabad is a political minefield. To make progress in reaching a permanent agreement to end the war, he will have to satisfy several stakeholders with competing interests, and who all distrust each other after a six-week military campaign that has engulfed the Middle East and roiled the global economy.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"US allies are watching Vance closely to see how he'll perform, one European official said. Vance \\\"needs to step into the room and deliver something,\\\" added the official, who spoke on the condition of anonymity. \\\"Otherwise he will be diminished.\\\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"US allies are watching Vance closely to see how he'll perform, one European official said. Vance \\\"needs to step into the room and deliver something,\\\" added the official, who spoke on the condition of anonymity. \\\"Otherwise he will be diminished.\\\"\",\"attributes\":[]}}]}}]}},{\"type\":\"advertisement\",\"model\":{\"adType\":\"horizontal\"},\"incrementedType\":\"mid_1\"},{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"caption\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"The US president says he's delivering peace through strength\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"The US president says he's delivering peace through strength\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"President Donald Trump mimics firing a gun during a news conference in the White House briefing room \",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"President Donald Trump mimics firing a gun during a news conference in the White House briefing room \",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":1920,\"height\":1280,\"locator\":\"f56c/live/f1a283b0-34c4-11f1-8606-05fe34b06e1b.jpg\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"Inc via Getty Images\",\"suitableForSyndication\":true}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Any deal must win the support first and foremost of Trump, who has vacillated between calling for peace and threatening to destroy Iran's civilisation. It will also need the backing of a weakened but still-standing regime in Tehran that has tightened control over the Strait of Hormuz, and an ally in Israel that is wary of a region-wide ceasefire. US allies in Europe that oppose the war and have been reluctant to come to America's aid in reopening the strait will also have to be convinced.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Any deal must win the support first and foremost of Trump, who has vacillated between calling for peace and threatening to destroy Iran's civilisation. It will also need the backing of a weakened but still-standing regime in Tehran that has tightened control over the Strait of Hormuz, and an ally in Israel that is wary of a region-wide ceasefire. US allies in Europe that oppose the war and have been reluctant to come to America's aid in reopening the strait will also have to be convinced.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"As if that's not enough, Vance will also face pressure to somehow satisfy Trump's Make America Great Again (MAGA) base. Many are opposed to interventions abroad so will be watching his trip closely for clues about how he might handle foreign policy if he runs for president in 2028. \",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"As if that's not enough, Vance will also face pressure to somehow satisfy Trump's Make America Great Again (MAGA) base. Many are opposed to interventions abroad so will be watching his trip closely for clues about how he might handle foreign policy if he runs for president in 2028. \",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"A former Marine who served in Iraq, Vance has been a vocal opponent of US entanglements in the past, and reportedly expressed deep scepticism about launching strikes on Iran in private meetings with Trump, according to a New York Times report.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"A former Marine who served in Iraq, Vance has been a vocal opponent of US entanglements in the past, and reportedly expressed deep scepticism about launching strikes on Iran in private meetings with Trump, according to a New York Times report.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\\\"Vance has signalled a desire for restraint in American foreign policy. That's pretty hard to square with the American war against Iran,\\\" said Jeff Rathke, the president of the American-German Institute, a Washington-based think tank.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\\\"Vance has signalled a desire for restraint in American foreign policy. That's pretty hard to square with the American war against Iran,\\\" said Jeff Rathke, the president of the American-German Institute, a Washington-based think tank.\",\"attributes\":[]}}]}}]}},{\"type\":\"advertisement\",\"model\":{\"adType\":\"horizontal\"},\"incrementedType\":\"mid_2\"},{\"type\":\"subheadline\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Satisfying a demanding boss\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Satisfying a demanding boss\",\"attributes\":[]}}]}}]}}],\"level\":2}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"In Islamabad the question for Vance is: can he make everyone happy? And what does success in these negotiations look like - a fully-formed peace deal, or just productive initial talks that don't scuttle the temporary ceasefire?\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"In Islamabad the question for Vance is: can he make everyone happy? And what does success in these negotiations look like - a fully-formed peace deal, or just productive initial talks that don't scuttle the temporary ceasefire?\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"A White House official told the BBC that Trump had tasked the vice-president to lead the negotiations. And spokeswoman Anna Kelly confirmed that Vance had already been collaborating with special envoy Steve Witkoff and the president's son-in-law Jared Kushner, both of whom will be with him in Pakistan. \",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"A White House official told the BBC that Trump had tasked the vice-president to lead the negotiations. And spokeswoman Anna Kelly confirmed that Vance had already been collaborating with special envoy Steve Witkoff and the president's son-in-law Jared Kushner, both of whom will be with him in Pakistan. \",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Vance tamped down expectations before leaving Washington on Friday morning.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Vance tamped down expectations before leaving Washington on Friday morning.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\\\"If the Iranians are willing to negotiate in good faith, we are certainly willing to extend an open hand,\\\" Vance told reporters. He also warned Iran not to \\\"play us,\\\" and said Trump gave the US negotiating team \\\"some pretty clear guidelines\\\".\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\\\"If the Iranians are willing to negotiate in good faith, we are certainly willing to extend an open hand,\\\" Vance told reporters. He also warned Iran not to \\\"play us,\\\" and said Trump gave the US negotiating team \\\"some pretty clear guidelines\\\".\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"But even if he laid out clear goalposts ahead of time, the president has a propensity to change his mind. In the talks with Iran, Vance and the rest of the US team will face the added challenge of representing a mercurial boss in Trump who has given a range of rationales for the war since launching the conflict in late February.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"But even if he laid out clear goalposts ahead of time, the president has a propensity to change his mind. In the talks with Iran, Vance and the rest of the US team will face the added challenge of representing a mercurial boss in Trump who has given a range of rationales for the war since launching the conflict in late February.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"On Friday afternoon, when asked what he told Vance before he left for Islamabad, Trump told reporters: \\\"I wish him luck. He's got a big thing.\\\" The president said he was sending a \\\"good team\\\" and \\\"we'll see how it all turns out.\\\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"On Friday afternoon, when asked what he told Vance before he left for Islamabad, Trump told reporters: \\\"I wish him luck. He's got a big thing.\\\" The president said he was sending a \\\"good team\\\" and \\\"we'll see how it all turns out.\\\"\",\"attributes\":[]}}]}}]}},{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"caption\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Control of the Strait of Hormuz means the weakened Iranian regime still has leverage\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Control of the Strait of Hormuz means the weakened Iranian regime still has leverage\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Iranians hold national flags beneath a large billboard reading \\\"The Strait of Hormuz remains closed\\\" as people gather in Tehran's Revolution Square\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Iranians hold national flags beneath a large billboard reading \\\"The Strait of Hormuz remains closed\\\" as people gather in Tehran's Revolution Square\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":1920,\"height\":1280,\"locator\":\"bef3/live/e8c958e0-34c4-11f1-8606-05fe34b06e1b.jpg\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"AFP via Getty Images\",\"suitableForSyndication\":true}}]}},{\"type\":\"advertisement\",\"model\":{\"adType\":\"horizontal\"},\"incrementedType\":\"mid_3\"},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Trump's volatile negotiating style was on full display this week, in the whirlwind period leading up to the ceasefire deal reached on Tuesday. In a single 36-hour span, Trump gave Iran one day to strike a deal, warned in social media posts on Truth Social that \\\"a whole civilisation will die\\\" if Iran refused to cooperate, and then finally announced a ceasefire with less than two hours left before his deadline for escalating the war.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Trump's volatile negotiating style was on full display this week, in the whirlwind period leading up to the ceasefire deal reached on Tuesday. In a single 36-hour span, Trump gave Iran one day to strike a deal, warned in social media posts on Truth Social that \\\"a whole civilisation will die\\\" if Iran refused to cooperate, and then finally announced a ceasefire with less than two hours left before his deadline for escalating the war.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"The tense hours on Tuesday were as nervewracking as any moments in Trump's second term, said a second senior European diplomat.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"The tense hours on Tuesday were as nervewracking as any moments in Trump's second term, said a second senior European diplomat.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\\\"I went home from work, put on the news, and started refreshing Truth Social,\\\" said the official, who spoke on the condition of anonymity. Serving as Trump's vice-president can't be easy under normal conditions, the diplomat added, but must be especially difficult for Vance right now given his misgivings about foreign wars.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\\\"I went home from work, put on the news, and started refreshing Truth Social,\\\" said the official, who spoke on the condition of anonymity. Serving as Trump's vice-president can't be easy under normal conditions, the diplomat added, but must be especially difficult for Vance right now given his misgivings about foreign wars.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\\\"Vance has tried to distance himself from the Iran campaign,\\\" the source said. \\\"This war is absolutely not in his playbook.\\\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\\\"Vance has tried to distance himself from the Iran campaign,\\\" the source said. \\\"This war is absolutely not in his playbook.\\\"\",\"attributes\":[]}}]}}]}},{\"type\":\"subheadline\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Ambassador for 'America First'\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Ambassador for 'America First'\",\"attributes\":[]}}]}}]}}],\"level\":2}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Representing Trump in high-stakes negotiations may be a challenge, but Vance has been working toward this moment since taking office. He has earned Trump's trust and been given a seat at the table in high-profile meetings and events with foreign policy leaders in the Oval Office and across Europe and Asia.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Representing Trump in high-stakes negotiations may be a challenge, but Vance has been working toward this moment since taking office. He has earned Trump's trust and been given a seat at the table in high-profile meetings and events with foreign policy leaders in the Oval Office and across Europe and Asia.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Vance made waves with a speech at the Munich Security Conference last year, where he issued a blistering critique of Europe's handling of immigration and free speech. Soon after, he accused Ukrainian President Volodymyr Zelensky of not being grateful enough for US aid during an explosive Oval Office meeting that descended into a shouting match. Just this week, the vice-president travelled to Hungary to make an unprecedented re-election push for the current prime minister and close Trump ally Viktor Orb\u00e1n.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Vance made waves with a speech at the Munich Security Conference last year, where he issued a blistering critique of Europe's handling of immigration and free speech. Soon after, he accused Ukrainian President Volodymyr Zelensky of not being grateful enough for US aid during an explosive Oval Office meeting that descended into a shouting match. Just this week, the vice-president travelled to Hungary to make an unprecedented re-election push for the current prime minister and close Trump ally Viktor Orb\u00e1n.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"At each step, Vance has positioned himself as a loyal lieutenant to Trump who's willing to crisscross the globe serving as a sharp-elbowed ambassador of \\\"America First\\\".\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"At each step, Vance has positioned himself as a loyal lieutenant to Trump who's willing to crisscross the globe serving as a sharp-elbowed ambassador of \\\"America First\\\".\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"The vice-president is the \\\"perfect surrogate\\\" in these high-stakes negotiations because of \\\"his firm understanding of President Trump's goals\\\", said Mark Bednar, who worked on the Trump-Vance transition team. \\\"To also have the trust of the president the way he does, that is a really great combination.\\\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"The vice-president is the \\\"perfect surrogate\\\" in these high-stakes negotiations because of \\\"his firm understanding of President Trump's goals\\\", said Mark Bednar, who worked on the Trump-Vance transition team. \\\"To also have the trust of the president the way he does, that is a really great combination.\\\"\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"But Vance reportedly hasn't always agreed with the president. And Trump's own foreign policy has sometimes put Vance in the awkward position of publicly backing the type of interventions abroad that he has argued against in the past - Iran being the prime example.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"But Vance reportedly hasn't always agreed with the president. And Trump's own foreign policy has sometimes put Vance in the awkward position of publicly backing the type of interventions abroad that he has argued against in the past - Iran being the prime example.\",\"attributes\":[]}}]}}]}},{\"type\":\"advertisement\",\"model\":{\"adType\":\"horizontal\"},\"incrementedType\":\"mid_4\"},{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"caption\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Trump's supporters are devoted - but not all support the war in Iran\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Trump's supporters are devoted - but not all support the war in Iran\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"A man wears a shirt supporting U.S. President Donald Trump and Hungarian Prime Minister Viktor Orban\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"A man wears a shirt supporting U.S. President Donald Trump and Hungarian Prime Minister Viktor Orban\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":1920,\"height\":1280,\"locator\":\"7ac7/live/fa15c0c0-34c4-11f1-8606-05fe34b06e1b.jpg\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"Reuters\",\"suitableForSyndication\":true}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"As a US senator Vance published a Wall Street Journal op-ed in 2023 saying he backed Trump because he didn't start foreign wars. On the eve of the Iran war, Vance told the Washington Post that Trump wouldn't let the US get dragged into another so-called forever war in the Middle East.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"As a US senator Vance published a Wall Street Journal op-ed in 2023 saying he backed Trump because he didn't start foreign wars. On the eve of the Iran war, Vance told the Washington Post that Trump wouldn't let the US get dragged into another so-called forever war in the Middle East.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"During the current conflict, he has publicly echoed Trump's argument that war was needed to prevent Iran from developing nuclear weapons. But Vance has not been as vocal in backing the war effort as other administration officials, in particular Defence Secretary Hegseth. Vance's rhetoric has also sometimes diverged from Trump's, as happened this week when Vance called the temporary ceasefire a \\\"fragile truce\\\".\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"During the current conflict, he has publicly echoed Trump's argument that war was needed to prevent Iran from developing nuclear weapons. But Vance has not been as vocal in backing the war effort as other administration officials, in particular Defence Secretary Hegseth. Vance's rhetoric has also sometimes diverged from Trump's, as happened this week when Vance called the temporary ceasefire a \\\"fragile truce\\\".\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Despite this, Trump tapped Vance to lead the US delegation to Islamabad. The choice raised questions of whether Trump purposely handed Vance a no-win assignment. The vice-president's office declined to comment for this story, but a US official who asked not to be named said Vance was chosen to send Iran a signal that the Trump administration was serious about reaching a deal.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Despite this, Trump tapped Vance to lead the US delegation to Islamabad. The choice raised questions of whether Trump purposely handed Vance a no-win assignment. The vice-president's office declined to comment for this story, but a US official who asked not to be named said Vance was chosen to send Iran a signal that the Trump administration was serious about reaching a deal.\",\"attributes\":[]}}]}}]}},{\"type\":\"advertisement\",\"model\":{\"adType\":\"horizontal\"},\"incrementedType\":\"mid_5\"},{\"type\":\"subheadline\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"No easy fix\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"No easy fix\",\"attributes\":[]}}]}}]}}],\"level\":2}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"US allies in the region welcomed Vance's inclusion on the team as a sign the administration wants a durable peace to end the war. \\\"It shows that America is seriously coming to the table,\\\" said Assaf Orion, a retired Israeli brigadier general.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"US allies in the region welcomed Vance's inclusion on the team as a sign the administration wants a durable peace to end the war. \\\"It shows that America is seriously coming to the table,\\\" said Assaf Orion, a retired Israeli brigadier general.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Vance will have to tune out the chatter back in Washington to deliver in negotiations with Iran.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Vance will have to tune out the chatter back in Washington to deliver in negotiations with Iran.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"The Oval Office confrontation with Zelensky and trips to Munich and Budapest all showcased Vance's ability to play the role of attack dog.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"The Oval Office confrontation with Zelensky and trips to Munich and Budapest all showcased Vance's ability to play the role of attack dog.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\\\"If he feels the need to be argumentative, he's not going to shy away from that. If he feels that something is not going right for the United States, he will not shy away from that either,\\\" said Mark Bednar, the Republican strategist.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\\\"If he feels the need to be argumentative, he's not going to shy away from that. If he feels that something is not going right for the United States, he will not shy away from that either,\\\" said Mark Bednar, the Republican strategist.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"But in Pakistan he's playing a different diplomatic role, which will require navigating tense relations between adversaries in a volatile region. Vance and his team will also have to address a complex set of problems - including reopening the Strait of Hormuz and ending Iran's nuclear programme - that are highly technical and have no easy fix.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"But in Pakistan he's playing a different diplomatic role, which will require navigating tense relations between adversaries in a volatile region. Vance and his team will also have to address a complex set of problems - including reopening the Strait of Hormuz and ending Iran's nuclear programme - that are highly technical and have no easy fix.\",\"attributes\":[]}}]}}]}},{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"caption\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Vance has had a prominent place for Oval Office encounters with world leaders\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Vance has had a prominent place for Oval Office encounters with world leaders\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Israeli Prime Minister Benjamin Netanyahu (L) speaks alongside U.S. President Donald Trump, Vice President JD Vance and Secretary of State Marco Rubio during a meeting in the Oval Office of the White House.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Israeli Prime Minister Benjamin Netanyahu (L) speaks alongside U.S. President Donald Trump, Vice President JD Vance and Secretary of State Marco Rubio during a meeting in the Oval Office of the White House.\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":1920,\"height\":1280,\"locator\":\"33f3/live/f5a56e50-34c4-11f1-9d5c-8ba507d7dbde.jpg\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"Getty Images\",\"suitableForSyndication\":true}}]}},{\"type\":\"advertisement\",\"model\":{\"adType\":\"horizontal\"},\"incrementedType\":\"mid_6\"},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Vance was not involved at a detailed level in the indirect talks between the US and Iran before the ceasefire. Negotiations in recent weeks were led by Witkoff and Kushner, according to a US official. The pair also spearheaded other peace talks during Trump's second term. The success of the talks will rely in part on who handles technical aspects of Iran's nuclear programme, Orion said.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Vance was not involved at a detailed level in the indirect talks between the US and Iran before the ceasefire. Negotiations in recent weeks were led by Witkoff and Kushner, according to a US official. The pair also spearheaded other peace talks during Trump's second term. The success of the talks will rely in part on who handles technical aspects of Iran's nuclear programme, Orion said.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\\\"Kushner and Witkoff did Ukraine, Iran and Gaza. I think it's very challenging to be a detailed expert in all three issues at the same time,\\\" Orion said. In Islamabad, \\\"the question is who else, who is on the bench?\\\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\\\"Kushner and Witkoff did Ukraine, Iran and Gaza. I think it's very challenging to be a detailed expert in all three issues at the same time,\\\" Orion said. In Islamabad, \\\"the question is who else, who is on the bench?\\\"\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Still Vance will command the most attention, regardless of whoever else is in the room. \",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Still Vance will command the most attention, regardless of whoever else is in the room. \",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"The vice-president won't be able to rely on a deep well of personal relationships with foreign leaders built up over years. It can be easy to forget Vance is still just 41 years old, and only recently launched himself onto the national political stage when he ran for the US Senate. For all of his polish and shrewd instincts, he is still a relative newcomer to the world of international relations.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"The vice-president won't be able to rely on a deep well of personal relationships with foreign leaders built up over years. It can be easy to forget Vance is still just 41 years old, and only recently launched himself onto the national political stage when he ran for the US Senate. For all of his polish and shrewd instincts, he is still a relative newcomer to the world of international relations.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Nevertheless, Trump threw him into the deep end this week, and now Vance is under pressure to deliver a victory for the president while not damaging his own political future.\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Nevertheless, Trump threw him into the deep end this week, and now Vance is under pressure to deliver a victory for the president while not damaging his own political future.\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\\\"He's not negotiating JD Vance's agreement with the Iranians. He's there in Islamabad to try to get the best deal the president can agree to,\\\" said Rathke. \\\"But that has some risks for the vice-president, in case Trump agrees to something and then later loses his enthusiasm for it. Trump may try to blame the negotiator.\\\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\\\"He's not negotiating JD Vance's agreement with the Iranians. He's there in Islamabad to try to get the best deal the president can agree to,\\\" said Rathke. \\\"But that has some risks for the vice-president, in case Trump agrees to something and then later loses his enthusiasm for it. Trump may try to blame the negotiator.\\\"\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\",\"attributes\":[]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Additional reporting by Grace Eliza Goodwin\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Additional reporting by Grace Eliza Goodwin\",\"attributes\":[\"italic\"]}}]}}]}},{\"type\":\"text\",\"model\":{\"suitableForAbridgement\":false,\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"\",\"attributes\":[]}}]}}]}},{\"type\":\"advertisement\",\"model\":{\"adType\":\"horizontal\"},\"incrementedType\":\"mid_7\"},{\"type\":\"links\",\"model\":{\"blocks\":[{\"type\":\"title\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"More from InDepth\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"More from InDepth\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"link\",\"model\":{\"blocks\":[{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"A treated collage featuring close up images of Benjamin Netanyahu and Donald Trump with the Iranian flag edited in the background\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"A treated collage featuring close up images of Benjamin Netanyahu and Donald Trump with the Iranian flag edited in the background\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":1920,\"height\":1080,\"locator\":\"5219/live/f4717b10-3428-11f1-8606-05fe34b06e1b.jpg\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"BBC\"}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Ceasefire or no ceasefire, the Middle East's reshuffling is not yet done\",\"blocks\":[{\"type\":\"urlLink\",\"model\":{\"text\":\"Ceasefire or no ceasefire, the Middle East's reshuffling is not yet done\",\"locator\":\"https://www.bbc.co.uk/news/articles/cp3l4yk5rlgo\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Ceasefire or no ceasefire, the Middle East's reshuffling is not yet done\",\"attributes\":[]}}],\"isExternal\":false}}]}}]}},{\"type\":\"aresLink\",\"model\":{\"blocks\":[{\"type\":\"optimoLinkMetadata\",\"model\":{\"timestamp\":1775775707745,\"consumableAsSFV\":false}}]}}],\"locator\":\"urn:bbc:optimo:asset:cp3l4yk5rlgo\",\"timestamp\":1775775707745}},{\"type\":\"link\",\"model\":{\"blocks\":[{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"A treated image of a airliner ascending to sky. In the background, a plume of smoke rises after a strike on the Iranian capital Tehran\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"A treated image of a airliner ascending to sky. In the background, a plume of smoke rises after a strike on the Iranian capital Tehran\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":1920,\"height\":1080,\"locator\":\"1543/live/c1c12910-2837-11f1-b297-95b0a0a8331e.jpg\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"Getty Images\"}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Prepare for turbulence - how a prolonged Middle East conflict could reshape how we fly\",\"blocks\":[{\"type\":\"urlLink\",\"model\":{\"text\":\"Prepare for turbulence - how a prolonged Middle East conflict could reshape how we fly\",\"locator\":\"https://www.bbc.co.uk/news/articles/cn08x9lw0pzo\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Prepare for turbulence - how a prolonged Middle East conflict could reshape how we fly\",\"attributes\":[]}}],\"isExternal\":false}}]}}]}},{\"type\":\"aresLink\",\"model\":{\"blocks\":[{\"type\":\"optimoLinkMetadata\",\"model\":{\"timestamp\":1774485676716,\"consumableAsSFV\":false}}]}}],\"locator\":\"urn:bbc:optimo:asset:cn08x9lw0pzo\",\"timestamp\":1774485676716}},{\"type\":\"link\",\"model\":{\"blocks\":[{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"On the right a statue of Saddam Hussein is toppled, and on the left is an image of Ayatollah Ali Khamenei \",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"On the right a statue of Saddam Hussein is toppled, and on the left is an image of Ayatollah Ali Khamenei \",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":1920,\"height\":1080,\"locator\":\"7df7/live/48199650-1c94-11f1-b048-c9424b2cf5fd.jpg\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"Anadolu Agency / Gamma - Rapho via Getty Images\"}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Mission accomplished? The 2003 boast that haunts today's Iran conflict\",\"blocks\":[{\"type\":\"urlLink\",\"model\":{\"text\":\"Mission accomplished? The 2003 boast that haunts today's Iran conflict\",\"locator\":\"https://www.bbc.co.uk/news/articles/c1e9yy84we8o\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Mission accomplished? The 2003 boast that haunts today's Iran conflict\",\"attributes\":[]}}],\"isExternal\":false}}]}}]}},{\"type\":\"aresLink\",\"model\":{\"blocks\":[{\"type\":\"optimoLinkMetadata\",\"model\":{\"timestamp\":1773360243409,\"consumableAsSFV\":false}}]}}],\"locator\":\"urn:bbc:optimo:asset:c1e9yy84we8o\",\"timestamp\":1773360243409}}]}},{\"type\":\"text\",\"model\":{\"suitableForAbridgement\":false,\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Top picture credits: Reuters and Getty Images\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Top picture credits: Reuters and Getty Images\",\"attributes\":[\"italic\"]}}]}}]}},{\"type\":\"image\",\"model\":{\"blocks\":[{\"type\":\"altText\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Thin, lobster red banner with white text saying \u2018InDepth newsletter\u2019. To the right are black and white portrait images of Emma Barnett and John Simpson. Emma has dark-rimmed glasses, long fair hair and a striped shirt. John has short white hair with a white shirt and dark blazer. They are set on an oatmeal, curved background with a green overlapping circle. \",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Thin, lobster red banner with white text saying \u2018InDepth newsletter\u2019. To the right are black and white portrait images of Emma Barnett and John Simpson. Emma has dark-rimmed glasses, long fair hair and a striped shirt. John has short white hair with a white shirt and dark blazer. They are set on an oatmeal, curved background with a green overlapping circle. \",\"attributes\":[]}}]}}]}}]}},{\"type\":\"rawImage\",\"model\":{\"width\":1600,\"height\":263,\"locator\":\"c006/live/24774480-ef9f-11f0-a422-4ba8a094a8fa.png\",\"originCode\":\"cpsprodpb\",\"copyrightHolder\":\"BBC\",\"suitableForSyndication\":true}}]}},{\"type\":\"text\",\"model\":{\"suitableForAbridgement\":false,\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"BBC InDepth is the home on the website and app for the best analysis, with fresh perspectives that challenge assumptions and deep reporting on the biggest issues of the day. Emma Barnett and John Simpson bring their pick of the most thought-provoking deep reads and analysis, every Saturday. Sign up for the newsletter here\",\"blocks\":[{\"type\":\"urlLink\",\"model\":{\"text\":\"BBC InDepth \",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"BBC InDepth \",\"attributes\":[\"italic\"]}}],\"locator\":\"https://www.bbc.co.uk/news/bbcindepth\",\"isExternal\":false}},{\"type\":\"fragment\",\"model\":{\"text\":\"is the home on the website and app for the best analysis, with fresh perspectives that challenge assumptions and deep reporting on the biggest issues of the day. Emma Barnett and John Simpson bring their pick of the most thought-provoking deep reads and analysis, every Saturday.\",\"attributes\":[\"italic\"]}},{\"type\":\"urlLink\",\"model\":{\"text\":\" Sign up for the newsletter here\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\" \",\"attributes\":[]}},{\"type\":\"fragment\",\"model\":{\"text\":\"Sign up for the newsletter here\",\"attributes\":[\"italic\"]}}],\"locator\":\"https://www.bbc.co.uk/newsletters/zqv4mbk\",\"isExternal\":false}}]}}]}},{\"type\":\"embed\",\"model\":{\"locator\":\"urn:bbc:ugc:campaign:u227176759\",\"provider\":\"ugc-uploader\",\"usageRights\":{\"suitableForSyndication\":true},\"blocks\":[{\"type\":\"aresUploader\",\"model\":{\"openingTime\":\"\",\"closingTime\":\"\",\"signinRequired\":false,\"campaignStatus\":\"open\",\"blocks\":[{\"type\":\"title\",\"model\":{\"blocks\":[{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Get in touch\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Get in touch\",\"attributes\":[]}}]}}]}}]}},{\"type\":\"text\",\"model\":{\"blocks\":[{\"type\":\"paragraph\",\"model\":{\"text\":\"Are you personally affected by the issues raised in this story?\",\"blocks\":[{\"type\":\"fragment\",\"model\":{\"text\":\"Are you personally affected by the issues raised in this story?\",\"attributes\":[]}}]}}]}},{\"type\":\"link\",\"model\":{\"locator\":\"urn:bbc:content:url-promo:https%3A%2F%2Fwww.bbc.co.uk%2Fsend%2Fu227176759\",\"blocks\